# ─────────────────────────────────────────────────────────────────
# Lead Dispatcher — Backend Environment Variables
# ─────────────────────────────────────────────────────────────────

# ─── DATABASE (REQUIRED) ─────────────────────────────────────────
# Neon Postgres connection string (free tier: https://neon.tech)
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/lead-dispatcher?sslmode=require

# ─── AUTH (REQUIRED) ─────────────────────────────────────────────
# JWT secret for signing auth tokens — generate with:
#   openssl rand -hex 32
JWT_SECRET=replace-with-64-char-random-hex-string

# ─── CREDENTIAL ENCRYPTION (REQUIRED) ────────────────────────────
# AES-256-GCM master key for encrypting SMTP/IMAP passwords.
# Generate with: openssl rand -hex 32
# WARNING: If this changes, existing encrypted credentials become unreadable.
ENCRYPTION_KEY=replace-with-64-char-random-hex-string

# ─── CORS (REQUIRED) ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# After Vercel deploys, set this to your Vercel URL.
FRONTEND_URL=https://cold-outreach-frontend.vercel.app

# ─── PUBLIC URL (REQUIRED) ───────────────────────────────────────
# Used for unsubscribe links in email footers.
# Set to your Vercel frontend URL.
PUBLIC_BASE_URL=https://cold-outreach-frontend.vercel.app

# ─── DEEPSEEK LLM (OPTIONAL) ────────────────────────────────────
# For reply sentiment tagging (interested / not_interested / ooo / unsubscribe / neutral).
# Get your API key at: https://platform.deepseek.com
# If not set, LLM tagging is disabled — replies get null sentiment.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ─── PORT (Auto-set by Cloud Run) ────────────────────────────────
# Cloud Run sets this automatically. For local dev, defaults to 3001.
# PORT=8080
